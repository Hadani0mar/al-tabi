{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "reports-app",
  "version": "0.1.0",
  "identifier": "com.dell.reports-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "reports-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../QUERY_PATTERNS.md",
      "../PRODUCT_SCHEMA.md",
      "../DATABASE_VIEWS.md"
    ]
  }
}
