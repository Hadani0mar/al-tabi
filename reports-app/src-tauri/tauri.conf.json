{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "al-tabi",
  "version": "0.1.0",
  "identifier": "com.dell.reports-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "al-tabi",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../QUERY_PATTERNS.md",
      "../PRODUCT_SCHEMA.md",
      "../DATABASE_VIEWS.md"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ3N0RDRjU0RTM4RDQ4NkMKUldSc1NJM2pWTTk5MTFad1FLM3E1OXBwTGxWcFBTekIrbmtvbzhkVENXZmZmREhydHpUOEFsR3oK",
      "endpoints": [
        "https://github.com/Hadani0mar/al-tabi/releases/latest/download/latest.json"
      ]
    }
  }
}
